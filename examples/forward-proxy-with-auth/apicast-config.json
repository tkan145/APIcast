{
    "services": [
        {
            "backend_version": "1",
            "proxy": {
                "hosts": ["one"],
                "api_backend": "https://postman-echo.com/get",
                "backend": {
                    "endpoint": "http://127.0.0.1:8081",
                    "host": "backend"
                },
                "policy_chain": [
                    {
                        "name": "apicast.policy.apicast"
                    },
                    {
                        "name": "apicast.policy.http_proxy",
                        "configuration": {
                            "https_proxy": "http://foo:bar@proxy:443/"
                        }
                    }
                ],
                "proxy_rules": [
                    {
                        "http_method": "GET",
                        "pattern": "/",
                        "metric_system_name": "hits",
                        "delta": 1,
                        "parameters": [],
                        "querystring_parameters": {}
                    }
                ]
            }
        }
    ]
}
